<%- include('partials/header') %>
<main>
    <h1>Manage Users</h1>
    <p>All registered users in the system.</p>
    
    <div class="users-table-container">
        <table class="users-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Registered Date</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(function(user) { %>
                    <tr>
                        <td><%= user.user_id %></td>
                        <td><%= user.name %></td>
                        <td><%= user.email %></td>
                        <td class="role-<%= user.role_name.toLowerCase() %>">
                            <%= user.role_name %>
                        </td>
                        <td><%= user.created_at.toLocaleDateString() %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    
    <div class="back-link">
        <a href="/dashboard">← Back to Dashboard</a>
    </div>
</main>
<%- include('partials/footer') %>