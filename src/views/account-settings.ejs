<%- include('partials/header') %>
<main>
    <h1>Account Settings</h1>
    
    <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
    <% } %>
    
    <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
    <% } %>
    
    <div class="dashboard-sections">
        <!-- Profile Settings Section -->
        <div class="section">
            <h3>Profile Information</h3>
            <form action="/account-settings/profile" method="POST" class="settings-form">
                <div class="form-group">
                    <label for="name">Full Name</label>
                    <input type="text" id="name" name="name" value="<%= name %>" required class="form-control">
                </div>
                
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" value="<%= email %>" required class="form-control">
                </div>
                
                <button type="submit" class="btn">Update Profile</button>
            </form>
        </div>
        
        <!-- Password Change Section -->
        <div class="section">
            <h3>Change Password</h3>
            <form action="/account-settings/password" method="POST" class="settings-form">
                <div class="form-group">
                    <label for="current_password">Current Password</label>
                    <input type="password" id="current_password" name="current_password" required class="form-control">
                </div>
                
                <div class="form-group">
                    <label for="new_password">New Password</label>
                    <input type="password" id="new_password" name="new_password" required class="form-control">
                    <small>Password must be at least 6 characters</small>
                </div>
                
                <div class="form-group">
                    <label for="confirm_password">Confirm New Password</label>
                    <input type="password" id="confirm_password" name="confirm_password" required class="form-control">
                </div>
                
                <button type="submit" class="btn">Update Password</button>
            </form>
        </div>
    </div>
    
    <div class="back-link">
        <a href="/dashboard">← Back to Dashboard</a>
    </div>
</main>

<style>
    .settings-form {
        margin-top: 15px;
    }
    .settings-form .form-group {
        margin-bottom: 15px;
    }
    .settings-form .form-control {
        width: 100%;
        padding: 8px;
        border: 1px solid #ddd;
        border-radius: 4px;
    }
    .settings-form small {
        display: block;
        margin-top: 5px;
        color: #666;
    }
</style>

<%- include('partials/footer') %>