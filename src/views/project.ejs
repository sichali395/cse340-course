<%- include('partials/header') %>
<main>
    <h1><%= project.title %></h1>
    
    <% if (typeof message !== 'undefined' && message) { %>
        <div class="success-message"><%= message %></div>
    <% } %>
    
    <div class="project-details">
        <div class="project-info">
            <h2>Project Details</h2>
            <p><strong>Description:</strong> <%= project.description %></p>
            <p><strong>Date:</strong> <%= new Date(project.date).toLocaleDateString() %></p>
            <p><strong>Location:</strong> <%= project.location %></p>
            <p><strong>Organization:</strong> 
                <a href="/organization/<%= project.organization_id %>">
                    <%= project.organization_name %>
                </a>
            </p>
            
            <!-- Categories section - THIS IS CORRECT -->
            <div class="category-section">
                <p><strong>Categories:</strong>
                    <% if (categories && categories.length > 0) { %>
                        <% categories.forEach(category => { %>
                            <a href="/category/<%= category.id %>" class="tag"><%= category.name %></a>
                        <% }); %>
                    <% } else { %>
                        <span class="no-categories">No categories assigned yet</span>
                    <% } %>
                </p>
                <a href="/assign-categories/<%= project.project_id %>" class="btn-manage-categories">Manage Categories</a>
            </div>
        </div>
        
        <div class="project-actions">
            <h2>Get Involved</h2>
            <p>Interested in volunteering for this project? Contact the organization directly to sign up!</p>
            <a href="/organization/<%= project.organization_id %>" class="btn">Learn More About This Organization</a>
        </div>
    </div>
    
    <p><a href="/projects">← Back to all projects</a></p>
</main>
<%- include('partials/footer') %>