<%- include('partials/header') %>
<main>
    <h1><%= category.name %></h1>
    <% if (category.description) { %>
        <p><%= category.description %></p>
    <% } %>
    
    <h2>Projects in this Category</h2>
    
    <div class="projects-list">
        <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <div class="project-card">
                    <h2>
                        <a href="/project/<%= project.project_id %>">
                            <%= project.title %>
                        </a>
                    </h2>
                    <p><%= project.description %></p>
                    <p><strong>Organization:</strong> 
                        <a href="/organization/<%= project.organization_id %>">
                            <%= project.organization_name %>
                        </a>
                    </p>
                    <p><strong>Location:</strong> <%= project.location %></p>
                    <p><strong>Date:</strong> <%= new Date(project.date).toLocaleDateString() %></p>
                </div>
            <% }) %>
        <% } else { %>
            <p>No projects available in this category yet.</p>
        <% } %>
    </div>
    
    <p><a href="/categories">← Back to all categories</a></p>
</main>
<%- include('partials/footer') %>