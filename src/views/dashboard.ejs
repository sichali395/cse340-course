<%- include('partials/header') %>
<main>
    <h1>My Dashboard</h1>
    
    <% if (error === 'access_denied') { %>
        <div class="alert alert-danger">You don't have permission to access that page.</div>
    <% } %>
    
    <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
    <% } %>
    
    <div class="welcome-section">
        <h2>Welcome back, <%= name %>!</h2>
        <p>Email: <%= email %></p>
        <p>Role: <%= user.role_id === 2 ? 'Administrator' : 'User' %></p>
    </div>
    
    <div class="dashboard-sections">
        <!-- My Volunteering Projects Section -->
        <div class="section">
            <h3>My Volunteering Projects</h3>
            <% if (volunteerProjects && volunteerProjects.length > 0) { %>
                <ul class="volunteer-list">
                    <% volunteerProjects.forEach(function(project) { %>
                        <li>
                            <strong><%= project.title %></strong><br>
                            <em><%= project.organization_name %></em><br>
                            Location: <%= project.location %><br>
                            Date: <%= new Date(project.date).toLocaleDateString() %><br>
                            <form action="/project/<%= project.project_id %>/remove-volunteer" method="POST" class="inline-form">
                                <button type="submit" class="btn-remove">Remove</button>
                            </form>
                            <a href="/project/<%= project.project_id %>">View Details</a>
                        </li>
                    <% }); %>
                </ul>
            <% } else { %>
                <p>You haven't volunteered for any projects yet.</p>
                <a href="/projects">Browse Projects to Volunteer</a>
            <% } %>
        </div>
        
        <!-- My Activity Section -->
        <div class="section">
            <h3>My Activity</h3>
            <p>View your volunteer history and upcoming commitments.</p>
            <a href="/my-projects">View My Projects</a>
        </div>
        
        <!-- Account Settings Section -->
        <div class="section">
            <h3>Account Settings</h3>
            <p>Update your profile and preferences.</p>
            <a href="/account-settings">Edit Settings</a>
        </div>
        
        <!-- Admin Controls Section (Only visible to Admin users) -->
        <% if (user.role_id === 2) { %>
            <div class="section admin-section">
                <h3>Admin Controls</h3>
                <p>Manage system users and settings.</p>
                <a href="/users">Manage Users</a>
                <a href="/new-category">Create New Category</a>
            </div>
        <% } %>
    </div>
    
    <div class="back-link">
        <a href="/">← Back to Home</a>
    </div>
</main>
<%- include('partials/footer') %>