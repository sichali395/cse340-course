<%- include('partials/header') %>
<main>
    <h1>Edit Project</h1>
    
    <% if (errors && errors.length > 0) { %>
        <div class="error-messages">
            <ul>
                <% errors.forEach(error => { %>
                    <li><%= error %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>
    
    <div class="form-container">
        <form action="/edit-project/<%= category.id %>" method="POST">
            <div class="form-group">
                <label for="organization_id">Organization:</label>
                <select id="organization_id" name="organization_id" required class="form-control">
                    <option value="">Select an organization</option>
                    <% organizations.forEach(org => { %>
                        <option value="<%= org.organization_id %>" <%= (formData.organization_id && formData.organization_id == org.organization_id) ? 'selected' : '' %>>
                            <%= org.name %>
                        </option>
                    <% }); %>
                </select>
            </div>
            
            <div class="form-group">
                <label for="title">Project Title:</label>
                <input type="text" id="title" name="title" value="<%= formData.title %>" maxlength="200" required class="form-control">
                <small>Maximum 200 characters</small>
            </div>
            
            <div class="form-group">
                <label for="description">Description:</label>
                <textarea id="description" name="description" required class="form-control" rows="5"><%= formData.description %></textarea>
            </div>
            
            <div class="form-group">
                <label for="location">Location:</label>
                <input type="text" id="location" name="location" value="<%= formData.location %>" maxlength="255" required class="form-control">
                <small>City, State</small>
            </div>
            
            <div class="form-group">
                <label for="date">Project Date:</label>
                <input type="date" id="date" name="date" value="<%= formData.date %>" required class="form-control">
            </div>
            
            <div class="form-actions">
                <button type="submit" class="btn">Update Project</button>
                <a href="/projects" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
    
    <p><a href="/projects">← Back to Projects</a></p>
</main>
<%- include('partials/footer') %>