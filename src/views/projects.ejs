<%- include('partials/header') %>
<main>
    <h1>Upcoming Service Projects</h1>
    
    <% if (typeof message !== 'undefined' && message) { %>
        <div class="success-message"><%= message %></div>
    <% } %>
    
    <div class="projects-list">
        <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <div class="project-card">
                    <h2><a href="/project/<%= project.project_id %>"><%= project.title %></a></h2>
                    <p><strong>Organization:</strong> <%= project.organization_name %></p>
                    <p><strong>Date:</strong> <%= new Date(project.date).toLocaleDateString() %></p>
                    <p><strong>Location:</strong> <%= project.location %></p>
                    <p><%= project.description %></p>
                    <a href="/project/<%= project.project_id %>" class="btn">View Details</a>
                </div>
            <% }); %>
        <% } else { %>
            <div class="no-data-message">
                <p>No upcoming projects found at this time.</p>
                <p>Check back later for new service opportunities!</p>
            </div>
        <% } %>
    </div>
    
    <p><a href="/">← Back to Home</a></p>
</main>
<%- include('partials/footer') %>