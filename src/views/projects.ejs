<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    
    <div class="projects-list">
        <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <div class="project-card">
                    <h2>
                        <a href="/project/<%= project.project_id %>">
                            <%= project.title %>
                        </a>
                    </h2>
                    <p><%= project.description %></p>
                    <p><strong>Organization:</strong> 
                        <a href="/organization/<%= project.organization_id %>">
                            <%= project.organization_name %>
                        </a>
                    </p>
                    <p><strong>Location:</strong> <%= project.location %></p>
                    <p><strong>Date:</strong> <%= new Date(project.date).toLocaleDateString() %></p>
                </div>
            <% }) %>
        <% } else { %>
            <p>No upcoming service projects at this time. Please check back later!</p>
        <% } %>
    </div>
    
    <p><a href="/organizations">View all partner organizations</a></p>
</main>
<%- include('partials/footer') %>