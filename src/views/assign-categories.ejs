<%- include('partials/header') %>
<main>
    <h1>Assign Categories to: <%= project.title %></h1>
    
    <% if (message) { %>
        <div class="success-message"><%= message %></div>
    <% } %>
    
    <% if (errors && errors.length > 0) { %>
        <div class="error-messages">
            <ul>
                <% errors.forEach(error => { %>
                    <li><%= error %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>
    
    <div class="form-container">
        <form action="/assign-categories/<%= project.project_id %>" method="POST" class="assign-form">
            <div class="form-group">
                <label>Select Categories:</label>
                <div class="checkbox-group">
                    <% if (categories && categories.length > 0) { %>
                        <% categories.forEach(category => { %>
                            <label class="checkbox-label">
                                <input type="checkbox" 
                                       name="categoryIds" 
                                       value="<%= category.id %>"
                                       <%= category.selected ? 'checked' : '' %>>
                                <%= category.name %>
                            </label>
                        <% }); %>
                    <% } else { %>
                        <p>No categories available. <a href="/new-category">Create a category first</a>.</p>
                    <% } %>
                </div>
                <small>Check all categories that apply to this project</small>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="btn">Save Category Assignments</button>
                <a href="/project/<%= project.project_id %>" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
    
    <p><a href="/project/<%= project.project_id %>">← Back to Project</a></p>
</main>

<%- include('partials/footer') %>