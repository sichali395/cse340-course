<%- include('partials/header') %>
<main>
    <h1><%= organizationDetails.name %></h1>
    
    <% if (typeof message !== 'undefined' && message) { %>
        <div class="success-message"><%= message %></div>
    <% } %>
    
    <div class="organization-details">
        <% if (organizationDetails.logo_filename) { %>
            <img src="/images/<%= organizationDetails.logo_filename %>" alt="<%= organizationDetails.name %> logo" class="organization-logo">
        <% } %>
        
        <div class="organization-info">
            <h2>About</h2>
            <p><%= organizationDetails.description %></p>
            
            <h2>Contact</h2>
            <p>Email: <a href="mailto:<%= organizationDetails.contact_email %>"><%= organizationDetails.contact_email %></a></p>
        </div>
        
        <div class="organization-projects">
            <h2>Service Projects</h2>
            <% if (projects && projects.length > 0) { %>
                <ul class="projects-list">
                    <% projects.forEach(project => { %>
                        <li>
                            <a href="/project/<%= project.project_id %>">
                                <h3><%= project.title %></h3>
                            </a>
                            <p><%= project.description %></p>
                            <p><strong>Location:</strong> <%= project.location %></p>
                            <p><strong>Date:</strong> <%= project.date %></p>
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p>No upcoming service projects at this time.</p>
            <% } %>
        </div>
    </div>
    
    <p><a href="/organizations">Back to all organizations</a></p>
</main>
<%- include('partials/footer') %>