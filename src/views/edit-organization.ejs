<%- include('partials/header') %>
<main>
    <h1>Edit Organization</h1>
    
    <% if (errors && errors.length > 0) { %>
        <div class="error-messages">
            <ul>
                <% errors.forEach(error => { %>
                    <li><%= error %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>
    
    <div class="form-container">
        <form action="/edit-organization/<%= category.id %>" method="POST">
            <div class="form-group">
                <label for="name">Organization Name:</label>
                <input type="text" id="name" name="name" value="<%= formData.name %>" maxlength="150" required class="form-control">
                <small>Maximum 150 characters</small>
            </div>
            
            <div class="form-group">
                <label for="description">Description:</label>
                <textarea id="description" name="description" required class="form-control" rows="5"><%= formData.description %></textarea>
            </div>
            
            <div class="form-group">
                <label for="contact_email">Contact Email:</label>
                <input type="email" id="contact_email" name="contact_email" value="<%= formData.contact_email %>" maxlength="255" required class="form-control">
                <small>Valid email address required</small>
            </div>
            
            <div class="form-group">
                <label for="logo_filename">Logo Filename:</label>
                <input type="text" id="logo_filename" name="logo_filename" value="<%= formData.logo_filename %>" class="form-control" placeholder="organization-logo.png">
                <small>Optional - filename of the logo image in /public/images/</small>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="btn">Update Organization</button>
                <a href="/organizations" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
    
    <p><a href="/organizations">← Back to Organizations</a></p>
</main>
<%- include('partials/footer') %>